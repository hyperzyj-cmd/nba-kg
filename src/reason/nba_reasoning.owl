<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://nba-kg.org/ontology"
         xmlns="http://nba-kg.org/ontology#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://nba-kg.org/ontology"/>

<owl:ObjectProperty rdf:about="#playsFor">
  <rdfs:domain rdf:resource="#Player"/>
  <rdfs:range rdf:resource="#Team"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#teammateOf">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
  <rdfs:domain rdf:resource="#Player"/>
  <rdfs:range rdf:resource="#Player"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#wonMVP">
  <rdfs:domain rdf:resource="#Player"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Player">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Team">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#MVPWinner">
  <rdfs:subClassOf rdf:resource="#Player"/>
</owl:Class>

<owl:Class rdf:about="#Teammate">
  <rdfs:subClassOf rdf:resource="#Player"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#Los_Angeles_Lakers">
  <rdf:type rdf:resource="#Team"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Los Angeles Lakers</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#LeBron_James">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#Los_Angeles_Lakers"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LeBron James</rdfs:label>
  <wonMVP rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</wonMVP>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Anthony_Davis">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#Los_Angeles_Lakers"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anthony Davis</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Golden_State_Warriors">
  <rdf:type rdf:resource="#Team"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Golden State Warriors</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Stephen_Curry">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#Golden_State_Warriors"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stephen Curry</rdfs:label>
  <wonMVP rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</wonMVP>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kevin_Durant">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#Golden_State_Warriors"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kevin Durant</rdfs:label>
  <wonMVP rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</wonMVP>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Klay_Thompson">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#Golden_State_Warriors"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Klay Thompson</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Boston_Celtics">
  <rdf:type rdf:resource="#Team"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Boston Celtics</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Jayson_Tatum">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#Boston_Celtics"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Jayson Tatum</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Jaylen_Brown">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#Boston_Celtics"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Jaylen Brown</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Milwaukee_Bucks">
  <rdf:type rdf:resource="#Team"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Milwaukee Bucks</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Giannis_Antetokounmpo">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#Milwaukee_Bucks"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Giannis Antetokounmpo</rdfs:label>
  <wonMVP rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</wonMVP>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Damian_Lillard">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#Milwaukee_Bucks"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Damian Lillard</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Denver_Nuggets">
  <rdf:type rdf:resource="#Team"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Denver Nuggets</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Nikola_Jokic">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#Denver_Nuggets"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nikola Jokic</rdfs:label>
  <wonMVP rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</wonMVP>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Jamal_Murray">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#Denver_Nuggets"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Jamal Murray</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Dallas_Mavericks">
  <rdf:type rdf:resource="#Team"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dallas Mavericks</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Luka_Doncic">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#Dallas_Mavericks"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Luka Doncic</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kyrie_Irving">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#Dallas_Mavericks"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kyrie Irving</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Philadelphia_76ers">
  <rdf:type rdf:resource="#Team"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Philadelphia 76ers</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Joel_Embiid">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#Philadelphia_76ers"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Joel Embiid</rdfs:label>
  <wonMVP rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</wonMVP>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#San_Antonio_Spurs">
  <rdf:type rdf:resource="#Team"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">San Antonio Spurs</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Victor_Wembanyama">
  <rdf:type rdf:resource="#Player"/>
  <playsFor rdf:resource="#San_Antonio_Spurs"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Victor Wembanyama</rdfs:label>
</owl:NamedIndividual>

<swrl:Variable rdf:about="urn:swrl#x"/>

<swrl:Variable rdf:about="urn:swrl#y"/>

<swrl:Variable rdf:about="urn:swrl#t"/>

<owl:AllDifferent>
  <owl:distinctMembers rdf:parseType="Collection">
    <rdf:Description rdf:about="#Los_Angeles_Lakers"/>
    <rdf:Description rdf:about="#Golden_State_Warriors"/>
    <rdf:Description rdf:about="#Boston_Celtics"/>
    <rdf:Description rdf:about="#Milwaukee_Bucks"/>
    <rdf:Description rdf:about="#Denver_Nuggets"/>
    <rdf:Description rdf:about="#Dallas_Mavericks"/>
    <rdf:Description rdf:about="#Philadelphia_76ers"/>
    <rdf:Description rdf:about="#San_Antonio_Spurs"/>
  </owl:distinctMembers>
</owl:AllDifferent>

<owl:AllDifferent>
  <owl:distinctMembers rdf:parseType="Collection">
    <rdf:Description rdf:about="#LeBron_James"/>
    <rdf:Description rdf:about="#Anthony_Davis"/>
    <rdf:Description rdf:about="#Stephen_Curry"/>
    <rdf:Description rdf:about="#Kevin_Durant"/>
    <rdf:Description rdf:about="#Klay_Thompson"/>
    <rdf:Description rdf:about="#Jayson_Tatum"/>
    <rdf:Description rdf:about="#Jaylen_Brown"/>
    <rdf:Description rdf:about="#Giannis_Antetokounmpo"/>
    <rdf:Description rdf:about="#Damian_Lillard"/>
    <rdf:Description rdf:about="#Nikola_Jokic"/>
    <rdf:Description rdf:about="#Jamal_Murray"/>
    <rdf:Description rdf:about="#Luka_Doncic"/>
    <rdf:Description rdf:about="#Kyrie_Irving"/>
    <rdf:Description rdf:about="#Joel_Embiid"/>
    <rdf:Description rdf:about="#Victor_Wembanyama"/>
  </owl:distinctMembers>
</owl:AllDifferent>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Player"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:DatavaluedPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#wonMVP"/>
              <swrl:argument1 rdf:resource="urn:swrl#x"/>
              <swrl:argument2 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrl:argument2>
            </swrl:DatavaluedPropertyAtom>
          </rdf:first>
          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#MVPWinner"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Player"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:ClassAtom>
              <swrl:classPredicate rdf:resource="#Player"/>
              <swrl:argument1 rdf:resource="urn:swrl#y"/>
            </swrl:ClassAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:ClassAtom>
                  <swrl:classPredicate rdf:resource="#Team"/>
                  <swrl:argument1 rdf:resource="urn:swrl#t"/>
                </swrl:ClassAtom>
              </rdf:first>
              <rdf:rest>
                <rdf:Description>
                  <rdf:first>
                    <swrl:IndividualPropertyAtom>
                      <swrl:propertyPredicate rdf:resource="#playsFor"/>
                      <swrl:argument1 rdf:resource="urn:swrl#x"/>
                      <swrl:argument2 rdf:resource="urn:swrl#t"/>
                    </swrl:IndividualPropertyAtom>
                  </rdf:first>
                  <rdf:rest>
                    <rdf:Description>
                      <rdf:first>
                        <swrl:IndividualPropertyAtom>
                          <swrl:propertyPredicate rdf:resource="#playsFor"/>
                          <swrl:argument1 rdf:resource="urn:swrl#y"/>
                          <swrl:argument2 rdf:resource="urn:swrl#t"/>
                        </swrl:IndividualPropertyAtom>
                      </rdf:first>
                      <rdf:rest>
                        <rdf:Description>
                          <rdf:first>
                            <swrl:DifferentIndividualsAtom>
                              <swrl:argument1 rdf:resource="urn:swrl#x"/>
                              <swrl:argument2 rdf:resource="urn:swrl#y"/>
                            </swrl:DifferentIndividualsAtom>
                          </rdf:first>
                          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                        </rdf:Description>
                      </rdf:rest>
                    </rdf:Description>
                  </rdf:rest>
                </rdf:Description>
              </rdf:rest>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#teammateOf"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
          <swrl:argument2 rdf:resource="urn:swrl#y"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>


</rdf:RDF>
